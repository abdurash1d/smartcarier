# =============================================================================
# SmartCareer AI - Environment Variables Template
# =============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env
#    cp env.example .env
# 
# 2. Fill in your actual values
# 
# 3. NEVER commit .env to Git!
#
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=SmartCareer AI
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=CHANGE-THIS-TO-RANDOM-32-CHAR-STRING-USE-COMMAND-BELOW

# Generate SECRET_KEY with:
# python -c "import secrets; print(secrets.token_hex(32))"

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Development (SQLite)
DATABASE_URL=sqlite:///./smartcareer.db

# Production (PostgreSQL) - Uncomment and configure
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# CORS & FRONTEND
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Production - Add your domain:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# AI SERVICES (Choose one or both)
# -----------------------------------------------------------------------------

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# EMAIL SERVICE
# -----------------------------------------------------------------------------

# Option 1: SendGrid (Recommended for production)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@smartcareer.ai
EMAIL_FROM_NAME=SmartCareer AI

# Option 2: Gmail SMTP (For development/testing)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password

# Option 3: Mailgun
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.yourdomain.com

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS
# -----------------------------------------------------------------------------

# Stripe (International)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# For production, use live keys:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Payme (Uzbekistan)
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key
PAYME_ENDPOINT=https://checkout.paycom.uz

# Test mode:
# PAYME_ENDPOINT=https://test.paycom.uz

# -----------------------------------------------------------------------------
# ERROR TRACKING
# -----------------------------------------------------------------------------

# Sentry (Highly Recommended for Production!)
SENTRY_DSN=https://your-sentry-dsn-here
SENTRY_ENVIRONMENT=development
# Change to 'production' when deploying

# -----------------------------------------------------------------------------
# CACHING (Optional - Improves Performance)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# Cloud Redis (Production):
# REDIS_URL=redis://username:password@host:port/0

# -----------------------------------------------------------------------------
# FILE STORAGE (Optional - For uploads)
# -----------------------------------------------------------------------------

# Local Storage (Development)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (Production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=smartcareer-uploads
# AWS_S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# -----------------------------------------------------------------------------
# PRODUCTION CHECKLIST
# -----------------------------------------------------------------------------
#
# Before deploying to production:
#
# [ ] Set DEBUG=False
# [ ] Generate new SECRET_KEY
# [ ] Use PostgreSQL DATABASE_URL
# [ ] Add production CORS_ORIGINS
# [ ] Use production Stripe keys (sk_live_...)
# [ ] Configure email service (SendGrid recommended)
# [ ] Add Sentry DSN for error tracking
# [ ] Set SENTRY_ENVIRONMENT=production
# [ ] Configure backup strategy
# [ ] Setup Redis for caching (optional but recommended)
# [ ] Configure AWS S3 for file uploads (optional)
# [ ] Test all environment variables
# [ ] NEVER commit .env to Git!
#
# =============================================================================
