# =============================================================================
# SmartCareer AI - PRODUCTION Environment Variables
# =============================================================================
# 
# CRITICAL: This is for PRODUCTION deployment!
# Do NOT use development values!
#
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION (PRODUCTION)
# -----------------------------------------------------------------------------
APP_NAME=SmartCareer AI
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=MUST-GENERATE-NEW-SECRET-KEY-FOR-PRODUCTION-64-CHARS

# Generate NEW SECRET_KEY:
# python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ NEVER reuse development SECRET_KEY in production!

# -----------------------------------------------------------------------------
# DATABASE (PRODUCTION - PostgreSQL REQUIRED!)
# -----------------------------------------------------------------------------
# ⚠️ SQLite is NOT recommended for production!
# Use PostgreSQL, MySQL, or other production database

# Railway/Render automatically provides DATABASE_URL
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# SECURITY (PRODUCTION)
# -----------------------------------------------------------------------------
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Production domains (CHANGE THESE!)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Security headers
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# AI SERVICES (PRODUCTION)
# -----------------------------------------------------------------------------

# Google Gemini (REQUIRED)
GEMINI_API_KEY=your-production-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# OpenAI (Optional)
OPENAI_API_KEY=sk-your-production-openai-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_ORG_ID=

# AI Rate Limiting (prevent cost overruns)
AI_MAX_REQUESTS_PER_USER_PER_DAY=50
AI_MAX_REQUESTS_PER_USER_PER_HOUR=10

# -----------------------------------------------------------------------------
# EMAIL SERVICE (REQUIRED FOR PRODUCTION!)
# -----------------------------------------------------------------------------

# SendGrid (Recommended)
SENDGRID_API_KEY=SG.your-production-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=SmartCareer AI
EMAIL_REPLY_TO=support@yourdomain.com

# Email templates
EMAIL_VERIFICATION_TEMPLATE_ID=d-xxx
EMAIL_PASSWORD_RESET_TEMPLATE_ID=d-xxx
EMAIL_WELCOME_TEMPLATE_ID=d-xxx

# Alternative: Mailgun
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.yourdomain.com

# Alternative: AWS SES
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY=your-access-key
# AWS_SES_SECRET_KEY=your-secret-key

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS (PRODUCTION - LIVE KEYS!)
# -----------------------------------------------------------------------------

# Stripe (LIVE KEYS!)
STRIPE_SECRET_KEY=sk_live_your-production-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-production-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-production-webhook-secret
STRIPE_API_VERSION=2023-10-16

# Payme (Uzbekistan - PRODUCTION)
PAYME_MERCHANT_ID=your-production-payme-merchant-id
PAYME_SECRET_KEY=your-production-payme-secret-key
PAYME_ENDPOINT=https://checkout.paycom.uz
PAYME_CALLBACK_URL=https://api.yourdomain.com/api/v1/payments/payme/callback

# Payment notifications
PAYMENT_SUCCESS_URL=https://yourdomain.com/payment/success
PAYMENT_CANCEL_URL=https://yourdomain.com/payment/cancel
PAYMENT_WEBHOOK_URL=https://api.yourdomain.com/api/v1/payments/webhook

# -----------------------------------------------------------------------------
# ERROR TRACKING & MONITORING (REQUIRED!)
# -----------------------------------------------------------------------------

# Sentry (Highly Recommended!)
SENTRY_DSN=https://your-production-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Log Level
LOG_LEVEL=WARNING
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# CACHING (HIGHLY RECOMMENDED!)
# -----------------------------------------------------------------------------

# Redis (Production)
REDIS_URL=redis://username:password@host:port/0
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# Cache settings
CACHE_TTL=300
CACHE_UNIVERSITY_TTL=3600
CACHE_JOB_TTL=600

# -----------------------------------------------------------------------------
# FILE STORAGE (PRODUCTION)
# -----------------------------------------------------------------------------

# AWS S3 (Recommended for production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=smartcareer-production-uploads
AWS_S3_REGION=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com
AWS_CLOUDFRONT_DOMAIN=d123456.cloudfront.net

# File upload limits
MAX_FILE_SIZE=10485760
MAX_IMAGE_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,gif

# -----------------------------------------------------------------------------
# RATE LIMITING (PRODUCTION)
# -----------------------------------------------------------------------------

# Global rate limits
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=3000
RATE_LIMIT_PER_DAY=50000

# Per-endpoint limits
RATE_LIMIT_AUTH_PER_HOUR=10
RATE_LIMIT_AI_PER_HOUR=20
RATE_LIMIT_API_PER_MINUTE=60

# -----------------------------------------------------------------------------
# BACKGROUND JOBS (Optional but recommended)
# -----------------------------------------------------------------------------

# Celery
CELERY_BROKER_URL=redis://host:port/1
CELERY_RESULT_BACKEND=redis://host:port/2
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# -----------------------------------------------------------------------------
# ANALYTICS & TRACKING
# -----------------------------------------------------------------------------

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# Mixpanel
MIXPANEL_TOKEN=your-mixpanel-token

# PostHog
POSTHOG_API_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# SOCIAL MEDIA & SEO
# -----------------------------------------------------------------------------

# Open Graph
OG_SITE_NAME=SmartCareer AI
OG_IMAGE=https://yourdomain.com/og-image.png
OG_DESCRIPTION=AI-powered career platform for Uzbekistan

# Twitter
TWITTER_SITE=@smartcareerai
TWITTER_CREATOR=@smartcareerai

# -----------------------------------------------------------------------------
# BACKUP & MAINTENANCE
# -----------------------------------------------------------------------------

# Backup configuration
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=smartcareer-backups

# Maintenance mode
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=We're upgrading! Back soon.

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------

# Features
ENABLE_REGISTRATION=True
ENABLE_AI_FEATURES=True
ENABLE_PAYMENTS=True
ENABLE_OAUTH=True
ENABLE_ADMIN_PANEL=True

# Beta features
ENABLE_UNIVERSITY_SEARCH=True
ENABLE_SCHOLARSHIP_MATCHING=True
ENABLE_AUTO_APPLY=False

# -----------------------------------------------------------------------------
# PERFORMANCE
# -----------------------------------------------------------------------------

# Workers (for Gunicorn)
WEB_CONCURRENCY=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_TIMEOUT=120
KEEP_ALIVE=5

# Database query optimization
DB_ECHO=False
DB_QUERY_TIMEOUT=10

# -----------------------------------------------------------------------------
# COMPLIANCE & LEGAL
# -----------------------------------------------------------------------------

# GDPR
ENABLE_GDPR_COMPLIANCE=True
DATA_RETENTION_DAYS=365
ALLOW_DATA_EXPORT=True
ALLOW_DATA_DELETION=True

# Cookie consent
COOKIE_CONSENT_REQUIRED=True

# -----------------------------------------------------------------------------
# PRODUCTION CHECKLIST
# -----------------------------------------------------------------------------
#
# Before deploying, verify:
#
# [ ] DEBUG=False
# [ ] New SECRET_KEY generated
# [ ] PostgreSQL DATABASE_URL configured
# [ ] Production CORS_ORIGINS set
# [ ] SSL/HTTPS enabled (SECURE_SSL_REDIRECT=True)
# [ ] Live Stripe keys (sk_live_...)
# [ ] Email service configured
# [ ] Sentry DSN added
# [ ] Redis configured (recommended)
# [ ] AWS S3 configured (recommended)
# [ ] Rate limiting enabled
# [ ] Backup enabled
# [ ] All domain names updated
# [ ] Environment variables verified
# [ ] Database migrations applied
# [ ] Static files deployed to CDN
# [ ] Health check endpoint working
# [ ] Monitoring alerts configured
# [ ] Support email configured
# [ ] Terms & Privacy pages updated
#
# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# ⚠️ NEVER commit this file with real values to Git!
# ⚠️ Use platform's secret management (Railway Secrets, Render Env Vars)
# ⚠️ Rotate all keys every 3-6 months
# ⚠️ Use different keys for staging and production
# ⚠️ Enable 2FA on all service accounts
# ⚠️ Monitor API usage and costs
# ⚠️ Setup alerts for unusual activity
# ⚠️ Regular security audits
#
# =============================================================================
