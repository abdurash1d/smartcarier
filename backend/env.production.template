# =============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE - SmartCareer AI
# =============================================================================
# Copy values to Railway/Vercel environment variables dashboard

# =============================================================================
# 🔐 SECURITY - CRITICAL!
# =============================================================================
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
DEBUG=false
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# 🤖 AI SERVICES
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# =============================================================================
# 🗄️ DATABASE - Railway auto-provides DATABASE_URL
# =============================================================================
# DATABASE_URL=auto-set-by-railway

# =============================================================================
# 🔴 REDIS - Railway auto-provides REDIS_URL
# =============================================================================
REDIS_ENABLED=true
# REDIS_URL=auto-set-by-railway

# =============================================================================
# 📧 EMAIL - Gmail SMTP
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@smartcareer.uz
SMTP_FROM_NAME=SmartCareer AI
SMTP_USE_TLS=true
FRONTEND_URL=https://your-app.vercel.app

# =============================================================================
# 🐛 ERROR MONITORING - Sentry
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# 🌐 CORS
# =============================================================================
CORS_ORIGINS=https://your-app.vercel.app,https://www.your-app.vercel.app

# =============================================================================
# 📁 FILE UPLOAD
# =============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# 🔐 OAUTH (Optional)
# =============================================================================
OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# 💳 PAYMENTS (Optional)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENTS_REQUIRE_WEBHOOK_SECRET=false

# =============================================================================
# 📊 APPLICATION
# =============================================================================
APP_NAME=SmartCareer AI
APP_VERSION=1.0.0
